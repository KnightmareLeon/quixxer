<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToggleButton?>

<?import io.github.knightmareleon.shared.ui.controls.IconButton?>
<?import io.github.knightmareleon.shared.ui.controls.NaturalNumberField?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.test.components.pages.TestSetupController"
    fx:id="vbox"
    style="-fx-padding:48; -fx-border-radius: 53; -fx-background-radius: 53;"
    spacing="24"
    alignment="TOP_LEFT"
    fillWidth="true"
    VBox.vgrow="ALWAYS">
    <HBox
        minHeight="48" 
        maxHeight="48"
        alignment="CENTER_LEFT">
        <Label fx:id="setupTitle" 
            styleClass="standard-header-font"/>
        <Region HBox.hgrow="ALWAYS" />
        <IconButton 
        iconLiteral="bi-box-arrow-left"
        styleClass="component-standard-bg"
        iconStyleClass="icon-base-color"
        minHeight="48"
        minWidth="48"
        onAction="#onBackPageClicked"/>
    </HBox>
    <Label 
        text="Test Constraints"
        styleClass="standard-header-font"/>
    <HBox
        alignment="CENTER_LEFT"
        spacing="12">
        <Label 
            text="Max Questions"
            styleClass="standard-font"
            labelFor="$totalQuestions"/>
        <NaturalNumberField 
            fx:id="totalQuestions"
            styleClass="standard-font"
            style="-fx-text-fill: black !important;"/>
        <Label fx:id="totalQuestionsMax"
            styleClass="standard-font"/>
    </HBox>
    <HBox
        alignment="CENTER_LEFT"
        spacing="12">
        <ToggleButton 
            text="Timed"
            fx:id="timeToggleButton"
            styleClass="component-standard-bg,white-border,standard-font"/>
        <ToggleButton 
            text="0:30"
            fx:id="thirtySecButton"
            styleClass="component-standard-bg,white-border,standard-font"/>
        <ToggleButton 
            text="1:00"
            fx:id="oneMinButton"
            styleClass="component-standard-bg,white-border,standard-font"/>
        <ToggleButton 
            text="3:00"
            fx:id="threeMinButton"
            styleClass="component-standard-bg,white-border,standard-font"/>
        <ToggleButton 
            text="5:00"
            fx:id="fiveMinButton"
            styleClass="component-standard-bg,white-border,standard-font"/>
        <ToggleButton 
            text="10:00"
            fx:id="tenMinButton"
            styleClass="component-standard-bg,white-border,standard-font"/>
    </HBox>
    <ToggleButton 
        text="Shuffled"
        fx:id="shuffleToggleButton"
        styleClass="component-standard-bg,white-border,standard-font"/>
    <Region VBox.vgrow="ALWAYS"/>
    <Button
        text="Start"
        maxWidth="Infinity"
        styleClass="component-standard-bg,standard-font,border-radius-15"
        onAction="#onStartClicked" />
</VBox>