<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>

<?import io.github.knightmareleon.shared.ui.controls.IconButton?>
<?import io.github.knightmareleon.shared.ui.controls.IconToggleButton?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.test.components.pages.TestSetsPickerController"
    fx:id="vbox"
    style="-fx-padding:48; -fx-border-radius: 53; -fx-background-radius: 53;"
    spacing="24"
    alignment="CENTER">
    <HBox
        minHeight="48" 
        maxHeight="48">
        <HBox>
            <IconToggleButton
                fx:id="cardViewButton"
                iconLiteral="fas-th-large"
                iconStyleClass="icon-base-color"
                styleClass="icon-button-base-bg"
                prefHeight="48"
                prefWidth="48"/>
            <IconToggleButton
                fx:id="listViewButton"
                iconLiteral="fas-bars"
                iconStyleClass="icon-base-color"
                styleClass="icon-button-base-bg"
                prefHeight="48"
                prefWidth="48"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="12">
            <TextField 
                promptText="Search"
                prefHeight="48"
                prefWidth="${vbox.width * 0.3679577464788732}"
                maxWidth="418"
                styleClass="border-radius-15,standard-font"
                style="-fx-text-fill: black !important"/>
            <IconButton 
                iconLiteral="bi-box-arrow-left"
                styleClass="component-standard-bg"
                iconStyleClass="icon-base-color"
                minHeight="48"
                minWidth="48"
                onAction="#onBackPageClicked"/>
        </HBox>
    </HBox>
    <ScrollPane fx:id="setsPane"
        maxWidth="1136"
        hbarPolicy="AS_NEEDED"
        vbarPolicy="AS_NEEDED"
        fitToWidth="true"
        fitToHeight="true"
        styleClass="standard-dark-bg"
        VBox.vgrow="ALWAYS">
        <HBox fx:id="setsContainer"
            spacing="24"
            alignment="TOP_LEFT"
            styleClass="standard-dark-bg">
        </HBox>
    </ScrollPane>
</VBox>