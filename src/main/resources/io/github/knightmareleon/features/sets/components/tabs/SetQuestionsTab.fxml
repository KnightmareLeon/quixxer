<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.VBox?>

<fx:root type="TabPane" 
    xmlns:fx="http://javafx.com/fxml/1"
    fx:id="questionsTab"
    VBox.vgrow="ALWAYS">
    <tabs>
        <Tab
            fx:id="identTab"
            text="Identification"
            closable="false"
            styleClass="component-standard-bg,standard-font">
            <content>
                <ScrollPane
                    maxWidth="1136"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    fitToWidth="true"
                    fitToHeight="true"
                    styleClass="standard-dark-bg">
                    <VBox
                        style="-fx-padding: 24 0 24 0"
                        spacing="24"
                        fillWidth="true"
                        styleClass="standard-dark-bg">
                        <VBox 
                            fx:id="identContainer"
                            spacing="24"
                            fillWidth="true"
                            styleClass="standard-dark-bg"/>
                        <Button 
                            fx:id="newIdnQstButton"
                            text="Add New Identification Question"
                            styleClass="component-standard-bg,border-radius-15,standard-font"
                            maxWidth="Infinity"/>
                    </VBox>
                    
                </ScrollPane>
            </content>
        </Tab>

        <Tab 
            fx:id="enumTab"
            text="Enumeration"
            closable="false"
            styleClass="component-standard-bg,standard-font">
            <content>
                <ScrollPane
                    maxWidth="1136"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    fitToWidth="true"
                    fitToHeight="true"
                    styleClass="standard-dark-bg">
                    <VBox 
                        style="-fx-padding: 24 0 24 0"
                        spacing="24"
                        fillWidth="true"
                        styleClass="standard-dark-bg">
                        <VBox 
                            fx:id="enumContainer"
                            spacing="24"
                            fillWidth="true"
                            styleClass="standard-dark-bg"/>
                        <Button 
                            fx:id="newEnmQstButton"
                            text="Add New Enumeration Question"
                            styleClass="component-standard-bg,border-radius-15,standard-font"
                            maxWidth="Infinity"/>
                    </VBox>
                </ScrollPane>
            </content>
        </Tab>
        <Tab
            fx:id="tofTab"
            text="True or False"
            closable="false"
            styleClass="component-standard-bg,standard-font">
            <content>
                <ScrollPane
                    maxWidth="1136"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    fitToWidth="true"
                    fitToHeight="true"
                    styleClass="standard-dark-bg">
                    <VBox
                        style="-fx-padding: 24 12 24 0"
                        spacing="24"
                        fillWidth="true"
                        styleClass="standard-dark-bg">
                        <VBox 
                            fx:id="tofContainer"
                            spacing="24"
                            fillWidth="true"
                            styleClass="standard-dark-bg"/>
                        <Button
                            fx:id="newTofQstButton"
                            text="Add New True or False Question"
                            styleClass="component-standard-bg,border-radius-15,standard-font"
                            maxWidth="Infinity"/>
                    </VBox>
                </ScrollPane>
            </content>
        </Tab>
    </tabs>
</fx:root>