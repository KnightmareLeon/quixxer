<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>

<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import io.github.knightmareleon.shared.ui.controls.IconButton?>
<?import io.github.knightmareleon.shared.ui.controls.IconToggleButton?>

<?import io.github.knightmareleon.features.sets.components.controls.SetDetailsCard?>

<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.sets.components.pages.SetDetailsController"
    fx:id="vbox"
    alignment="CENTER"
    style="-fx-border-radius: 53; -fx-background-radius: 53;"
    spacing="24"
    fillWidth="true">
    <HBox 
        spacing="12"
        alignment="CENTER">
        <FontIcon iconLiteral="dashicons-book-alt" iconSize="32" iconColor="white"/>
        <Label fx:id="setName"
            styleClass="standard-header-font"/>
        <IconToggleButton 
            fx:id="detailsToggleButton"
            text="Details"
            iconLiteral="bi-box-arrow-left"
            styleClass="icon-button-transparent-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"/>
        <IconToggleButton
            fx:id="questionToggleButton"
            text="Questions"
            iconLiteral="bi-box-arrow-left"
            styleClass="icon-button-transparent-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"/>
        <Region HBox.hgrow="ALWAYS" />
        <IconButton 
            iconLiteral="bi-pencil-square"
            styleClass="set-standard-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"/>
        <IconButton 
            iconLiteral="bi-trash-fill"
            styleClass="set-standard-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"
            onAction="#onDeleteClicked"/>
        <IconButton 
            iconLiteral="bi-box-arrow-left"
            styleClass="set-standard-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"
            onAction="#onBackPageClicked"/>
    </HBox>
    <VBox
        fx:id="tabsContainer"
        alignment="CENTER"
        spacing="24"
        fillWidth="true"
        VBox.vgrow="ALWAYS">

    </VBox>
</VBox>