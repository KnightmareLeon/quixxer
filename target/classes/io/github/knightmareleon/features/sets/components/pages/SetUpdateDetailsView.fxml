<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Button?>

<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import io.github.knightmareleon.shared.ui.controls.IconButton?>
<?import io.github.knightmareleon.features.sets.components.controls.QuestionField?>

<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.sets.components.pages.SetUpdateDetailsController"
    fx:id="vbox"
    alignment="CENTER_LEFT"
    style="-fx-border-radius: 53; -fx-background-radius: 53;"
    stylesheets="/io/github/knightmareleon/css/error.css"
    spacing="24"
    fillWidth="true">
    <HBox 
        spacing="12"
        alignment="CENTER">
        <FontIcon iconLiteral="bi-folder-symlink" iconSize="32" iconColor="white"/>
        <Label fx:id="updateSetTitle"
            styleClass="standard-header-font"/>
        <Region HBox.hgrow="ALWAYS" />
        <IconButton 
            iconLiteral="fas-save"
            styleClass="component-standard-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"
            onAction="#saveSet"/>
        <IconButton 
            iconLiteral="bi-box-arrow-left"
            styleClass="component-standard-bg"
            iconStyleClass="icon-base-color"
            minHeight="48"
            minWidth="48"
            onAction="#onBackPageClicked"/>
    </HBox>
    <HBox 
    spacing="12"
    alignment="CENTER_LEFT">
    <Label text="Set Title"
        styleClass="standard-header-font"/>
    <Label fx:id="titleErrorLabel"
        text="*Please fill in this field."
        styleClass="standard-font,error-font"
        visible="false"/>
    </HBox>
    <TextField
        fx:id="setTitle"
        styleClass="border-radius-15,standard-font"
        style="-fx-text-fill: black !important"
        minHeight="44"/>
    <HBox 
        spacing="12"
        alignment="CENTER_LEFT">
        <Label text="Subject"
            styleClass="standard-header-font"/>
        <Label fx:id="subjectErrorLabel"
            text="*Please fill in this field."
            styleClass="standard-font,error-font"
            visible="false"/>
    </HBox>
    <ComboBox fx:id="subjectPicker" 
        styleClass="border-radius-15, standard-font"
        style="-fx-text-base-color: black !important"
        minHeight="44">
    </ComboBox>
</VBox>