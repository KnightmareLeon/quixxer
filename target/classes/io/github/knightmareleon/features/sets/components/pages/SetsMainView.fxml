<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>

<?import io.github.knightmareleon.shared.ui.controls.IconButton?>
<?import io.github.knightmareleon.shared.ui.controls.IconToggleButton?>
<?import io.github.knightmareleon.shared.ui.controls.SetsLister?>
<?import io.github.knightmareleon.shared.ui.controls.Pagination?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.sets.components.pages.SetsMainController"
    fx:id="vbox"
    alignment="CENTER_LEFT"
    style="-fx-border-radius: 53; -fx-background-radius: 53;"
    spacing="24"
    fillWidth="true">
    <HBox
        minHeight="48" 
        maxHeight="48">
        <HBox>
            <IconToggleButton
                fx:id="cardViewButton"
                iconLiteral="fas-th-large"
                iconStyleClass="icon-base-color"
                styleClass="icon-button-base-bg"
                prefHeight="48"
                prefWidth="48"/>
            <IconToggleButton
                fx:id="listViewButton"
                iconLiteral="fas-bars"
                iconStyleClass="icon-base-color"
                styleClass="icon-button-base-bg"
                prefHeight="48"
                prefWidth="48"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="12">
            <IconButton
                text=" Create Set"
                iconLiteral="bi-folder-plus"
                iconStyleClass="icon-base-color"
                styleClass="component-standard-bg"
                prefHeight="48"
                maxWidth="256"
                onAction="#onCreateSetsClicked"/>
            <TextField 
                promptText="Search"
                prefHeight="48"
                prefWidth="${vbox.width * 0.3679577464788732}"
                maxWidth="418"
                styleClass="border-radius-15,standard-font"
                style="-fx-text-fill: black !important"/>
        </HBox>
    </HBox>
    <SetsLister 
        fx:id="setsLister"/>
    <Pagination 
        fx:id="pagination"/>
</VBox>