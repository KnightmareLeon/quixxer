<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<?import io.github.knightmareleon.features.test.components.controls.TestIconButton?>

<VBox
    alignment="CENTER"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.test.components.pages.TestMainController">
    <ScrollPane 
            maxWidth="1136"
            hbarPolicy="AS_NEEDED"
            vbarPolicy="AS_NEEDED"
            fitToWidth="true"
            styleClass="standard-dark-bg"
            style="-fx-background-radius: 53 0 0 53; -fx-border-radius: 53 0 0 53;">
        <VBox fx:id="vbox"
                alignment="CENTER"
                styleClass="standard-dark-bg"
                style="-fx-padding: 48; -fx-background-radius: 53 0 0 53; -fx-border-radius: 53 0 0 53;"
                spacing="48"
                fillWidth="true">
            <TestIconButton
                iconLiteral="fas-border-all"
                headerText="MULTIPLE CHOICE"
                descText="Test your skills by answering multiple choice questions."
                styleClass="mul-choice-bg"
                onAction="#onMultipleChoiceClicked">
            </TestIconButton>
            <TestIconButton
                iconLiteral="bi-card-text"
                headerText="FLASHCARDS"
                descText="Efficiently memorize information by using flashcards."
                styleClass="fc-test-bg"
                onAction="#onFlashcardClicked">
            </TestIconButton>
            <TestIconButton
                iconLiteral="bi-arrows-angle-contract"
                headerText="MATCHING TYPE"
                descText="Recognize patterns and similarities between two pieces of information."
                styleClass="match-type-test-bg"
                onAction="#onMatchingTypeClicked">
            </TestIconButton>
            <TestIconButton
                iconLiteral="bi-diagram-3-fill"
                headerText="ENUMERATION"
                descText="List down lists of items to remember organized details of a concept."
                styleClass="enum-test-bg"
                onAction="#onEnumerationClicked">
            </TestIconButton>
            <TestIconButton
                iconLiteral="bi-octagon-half"
                headerText="TRUE OR FALSE"
                descText="Assess yourself with a simple true or false test."
                styleClass="tof-test-bg"
                onAction="#onTrueOrFalseClicked">
            </TestIconButton>
            <TestIconButton
                iconLiteral="fas-chart-pie"
                headerText="COMBINED"
                descText="Combine multiple test types for the ultimate test of knowledge."
                styleClass="combined-test-bg"
                onAction="#onCombinedClicked">
            </TestIconButton>
        </VBox>
    </ScrollPane>
</VBox>