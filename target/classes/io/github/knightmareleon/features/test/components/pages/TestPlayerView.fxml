<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>

<?import io.github.knightmareleon.shared.ui.controls.IconButton?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="io.github.knightmareleon.features.test.components.pages.TestPlayerController"
    fx:id="vbox"
    style="-fx-padding:48; -fx-border-radius: 53; -fx-background-radius: 53;"
    spacing="24"
    alignment="CENTER_LEFT"
    VBox.vgrow="ALWAYS">
    <HBox
        minHeight="48" 
        maxHeight="48"
        alignment="CENTER_LEFT">
        <Label fx:id="testPlayerTitle" 
            styleClass="standard-header-font"/>
        <Region HBox.hgrow="ALWAYS" />
        <IconButton 
        iconLiteral="bi-box-arrow-left"
        styleClass="component-standard-bg"
        iconStyleClass="icon-base-color"
        minHeight="48"
        minWidth="48"
        onAction="#onBackPageClicked"/>
    </HBox>
    <StackPane>
        <ProgressBar 
            fx:id="incorrectProgressBar"
            maxWidth="Infinity"
            styleClass="scoreBar"
            style="-fx-accent: red"/>
        <ProgressBar 
            fx:id="correctProgressBar"
            maxWidth="Infinity"
            styleClass="scoreBar"
            style="-fx-accent: green"/>
    </StackPane>
    <HBox
        fillHeight="true"
        fx:id="mainContentHeader">
        <Label 
            fx:id="mainContentHeaderLabel" 
            styleClass="standard-header-font"/>
    </HBox>
    <ScrollPane
        vbarPolicy="AS_NEEDED"
        VBox.vgrow="ALWAYS"
        fitToHeight="true"
        fitToWidth="true"
        styleClass="standard-dark-bg">
        <BorderPane
            fx:id="mainContentPane"
            VBox.vgrow="ALWAYS">
        </BorderPane>
    </ScrollPane>
</VBox>